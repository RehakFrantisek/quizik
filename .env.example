# ======================
# Quizik Environment Config
# ======================
# Copy this file to .env and fill in the values.

# ── Database ──
POSTGRES_USER=quizik
POSTGRES_PASSWORD=quizik_dev_password
POSTGRES_DB=quizik
DATABASE_URL=postgresql+asyncpg://quizik:quizik_dev_password@postgres:5432/quizik

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Auth ──
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──
FRONTEND_URL=http://localhost:3000

# ── Email (dev: MailHog captures all) ──
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@quizik.local

# ── App ──
ENVIRONMENT=development
DEBUG=true
API_PORT=8000
WEB_PORT=3000
