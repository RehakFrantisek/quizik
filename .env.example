# ======================
# Quizik Environment Config
# ======================
# Copy this file to .env and fill in the values.

# ── Database ──
POSTGRES_USER=quizik
POSTGRES_PASSWORD=quizik_dev_password
POSTGRES_DB=quizik
DATABASE_URL=postgresql+asyncpg://quizik:quizik_dev_password@postgres:5432/quizik

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Auth ──
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth (optional — leave empty to disable Google login) ──
# To enable: create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3100/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend (Next.js) ──
# Token is stored in localStorage; these vars configure the Next.js app
NEXT_PUBLIC_API_BASE=http://localhost:3100

# ── CORS ──
FRONTEND_URL=http://localhost:3100

# ── Email (dev: MailHog captures all) ──
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@quizik.local

# ── App ──
ENVIRONMENT=development
DEBUG=true
API_PORT=8100
WEB_PORT=3100
